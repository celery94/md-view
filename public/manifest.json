{
  "name": "MD-View - Markdown Editor with Live Preview",
  "short_name": "MD-View",
  "description": "Online markdown editor with live preview. Import .md, export HTML, and print to PDF.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0f172a",
  "theme_color": "#0f172a",
  "orientation": "any",
  "scope": "/",
  "icons": [
    {
      "src": "/md-view-icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "categories": ["developer", "productivity", "utilities"],
  "lang": "en",
  "dir": "ltr",
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/markdown": [".md", ".markdown", ".mdown", ".mkd", ".mkdn", ".mdwn"]
      },
      "icons": [
        {
          "src": "/md-view-icon.svg",
          "sizes": "any",
          "type": "image/svg+xml"
        }
      ],
      "launch_type": "single-client"
    }
  ]
}
